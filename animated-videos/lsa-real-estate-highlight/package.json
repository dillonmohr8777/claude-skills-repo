    "@remotion/noise": "^4.0.290",
    "@remotion/paths": "^4.0.290",
    "@remotion/shapes": "^4.0.290",
    "@remotion/three": "^4.0.290",
    "@remotion/transitions": "^4.0.290",
    "@types/three": "^0.171.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.290",
    "three": "^0.171.0"
  },
