{
  "name": "lsa-real-estate-highlight",
  "version": "1.0.0",
  "description": "60-second animated highlight of 'Google Local Service Ads (LSA) & SEO for Real Estate Agents'",
  "private": true,
  "scripts": {
    "start": "remotion studio",
